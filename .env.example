# =============================================================================
# PLANTILLA FLASK - VARIABLES DE ENTORNO
# =============================================================================
# Copia este archivo a .env y rellena con tus valores reales
# IMPORTANTE: Nunca subas el archivo .env a git (ya está en .gitignore)
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION
# -----------------------------------------------------------------------------
# Configuración de la base de datos PostgreSQL
DB_NAME=nombre_de_tu_base_de_datos
DB_USER=postgres
DB_PASSWORD=tu_contraseña_de_postgres
DB_HOST=localhost
DB_PORT=5432

# -----------------------------------------------------------------------------
# SECURITY KEYS
# -----------------------------------------------------------------------------
# Clave para encriptación de datos sensibles
# Genera una con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=tu_clave_de_encriptacion_base64

# Clave secreta de Flask para CSRF y sesiones
# Genera una con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=tu_clave_secreta_flask_muy_larga_y_aleatoria

# -----------------------------------------------------------------------------
# WEBAUTHN / PASSKEYS CONFIGURATION
# -----------------------------------------------------------------------------
# Nombre de tu aplicación para WebAuthn
RP_NAME=Nombre de tu Aplicación

# URL de origen de tu aplicación (sin trailing slash)
ORIGIN=http://localhost:8000

# ID del Relying Party (generalmente tu dominio)
# Para desarrollo local usa "localhost"
RP_ID=localhost

# -----------------------------------------------------------------------------
# EMAIL CONFIGURATION
# -----------------------------------------------------------------------------
# Credenciales para envío de correos electrónicos
EMAIL_USUARIO=tu_email@ejemplo.com
EMAIL_CONTRASENA=tu_contraseña_de_aplicacion

# -----------------------------------------------------------------------------
# AWS S3 CONFIGURATION (Opcional)
# -----------------------------------------------------------------------------
# Solo necesario si usas almacenamiento en S3
AWS_REGION=us-east-2
AWS_ACCESS_KEY_ID=tu_access_key_id
AWS_SECRET_ACCESS_KEY=tu_secret_access_key
AWS_S3_BUCKET_NAME=nombre-de-tu-bucket

# -----------------------------------------------------------------------------
# ENVIRONMENT
# -----------------------------------------------------------------------------
# Entorno de ejecución: development o production
FLASK_ENV=development
